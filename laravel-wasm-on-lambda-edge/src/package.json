{
  "name": "php-wasm-edge-board",
  "version": "1.0.0",
  "description": "PHP-WASM 掲示板 on Lambda@Edge",
  "type": "module",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node18 --outdir=dist --format=esm --external:@php-wasm/node --external:pg-native",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/dsql-signer": "^3.0.0",
    "@php-wasm/node": "^0.9.0",
    "@php-wasm/universal": "^0.9.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.24.0",
    "fast-check": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
