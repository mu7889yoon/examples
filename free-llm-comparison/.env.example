# === Google Gemini ===
GEMINI_API_KEY=${GEMINI_API_KEY}
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# === Sakura AI ===
SAKURA_SECRET=${SAKURA_SECRET}
SAKURA_ENDPOINT=https://api.ai.sakura.ad.jp/v1
SAKURA_MODEL=gpt-oss-120b

# === Cloudflare Workers AI ===
CLOUDFLARE_ACCOUNT_ID=${CLOUDFLARE_ACCOUNT_ID}
CLOUDFLARE_API_KEY=${CLOUDFLARE_API_KEY}
CLOUDFLARE_MODEL=@cf/openai/gpt-oss-120b

# === io.net Intelligence ===
IONET_API_KEY=${IONET_API_KEY}
IONET_ENDPOINT=https://api.intelligence.io.solutions/api/v1
IONET_MODEL=openai/gpt-oss-120b

# === OpenRouter ===
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
